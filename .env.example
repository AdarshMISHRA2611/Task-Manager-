# Backend
DATABASE_URL=sqlite:///./ethara_local.db
# PostgreSQL example (Railway):
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE

# development | production
ENVIRONMENT=development

# Comma-separated browser origins (e.g. https://app.example.com). Use * only for debugging.
# Leave empty: dev defaults include Vite (5173); production uses strict same-origin unless you set this.
CORS_ORIGINS=

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server (Railway sets PORT automatically)
PORT=8000

# Frontend build-time (optional; leave empty to use same-origin `/api`)
VITE_API_URL=
